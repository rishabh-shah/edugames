{
  "name": "@edugames/game-validator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EduGames validator CLI for contributed HTML5 game bundles.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "edugames-game-validator": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "pretest": "pnpm --filter @edugames/contracts build",
    "pretypecheck": "pnpm --filter @edugames/contracts build",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts --configLoader runner",
    "lint": "node ../../scripts/placeholder-task.mjs @edugames/game-validator lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "tsx src/cli.ts"
  },
  "dependencies": {
    "@edugames/contracts": "workspace:*"
  }
}
